{
  "name": "fitness360",
  "version": "0.1.0",
  "private": false,
  "license": "Apache-2.0",
  "description": "Fitness360 — gym management (Next.js + Prisma)",
  "repository": {
    "type": "git",
    "url": "https://github.com/gymkhana-fitness-360/gymkhana.git"
  },
  "bugs": {
    "url": "https://github.com/gymkhana-fitness-360/gymkhana/issues"
  },
  "homepage": "https://github.com/gymkhana-fitness-360/gymkhana#readme",
  "engines": {
    "node": ">=20.9.0",
    "npm": ">=10.0.0"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "scripts": {
    "postinstall": "prisma generate",
    "vercel-build": "prisma generate && next build",
    "dev": "next dev --webpack",
    "dev:turbo": "next dev",
    "dev:skip-check": "next dev --webpack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "fitness360:init": "node packages/cli/bin/fitness360.js init --here",
    "import:payments": "tsx scripts/imports/archive/import-payments-xlsx.ts",
    "generate-icons": "node scripts/create-icons.js",
    "whatsapp:listener": "node scripts/whatsapp-listener.mjs",
    "whatsapp:poll": "node scripts/whatsapp-poll.mjs",
    "errors:comprehensive": "node scripts/error-monitor-comprehensive.mjs",
    "errors:report": "node scripts/error-monitor-comprehensive.mjs --report",
    "errors:monitor": "node scripts/error-monitor.mjs",
    "errors:watch": "node scripts/error-monitor.mjs --no-heal",
    "errors:summary": "node scripts/error-monitor.mjs summary",
    "errors:heals": "node scripts/error-monitor.mjs heals",
    "errors:clear": "node scripts/error-monitor.mjs clear",
    "errors:export": "node scripts/error-monitor.mjs export",
    "errors:structured": "node scripts/error-monitor.mjs structured",
    "validate": "tsx scripts/validate-cli.ts",
    "audit:api-routes": "node scripts/generate-api-route-audit.mjs",
    "audit:tenant-scope": "node scripts/audit-tenant-scope.mjs",
    "audit:tenant-scope:p0": "node scripts/audit-tenant-scope.mjs --fail-on-p0",
    "audit:api-routes:check": "node scripts/check-api-route-audit.mjs",
    "audit:grandfather-shrink": "node scripts/check-grandfather-shrink.mjs",
    "audit:route-line-limit": "node scripts/check-route-line-limit.mjs",
    "audit:mutating-zod": "node scripts/check-mutating-routes-zod.mjs",
    "openapi:generate": "node scripts/generate-openapi.mjs",
    "test:e2e:smoke": "playwright test e2e/login.spec.ts e2e/dashboard.spec.ts e2e/renewals-chase.spec.ts",
    "validate:business-rules": "tsx scripts/check-crud-business-rules.ts",
    "deploy": "./scripts/check-file-updates.sh && vercel --prod",
    "deploy:force": "./scripts/check-file-updates.sh --force && vercel --prod",
    "deploy:check": "BASE_URL=${BASE_URL:-http://localhost:3000} ./scripts/check-endpoints.sh",
    "deploy:stats": "tsx scripts/deployment-logger.ts stats",
    "deploy:failures": "tsx scripts/deployment-logger.ts failures",
    "test:endpoints": "tsx scripts/test-all-endpoints.ts",
    "test:endpoints:local": "BASE_URL=http://localhost:3000 ./scripts/check-endpoints.sh",
    "validate:quick": "tsx scripts/validate-cli.ts --quick",
    "validate:api": "tsx scripts/validate-cli.ts --api",
    "validate:ts": "tsx scripts/validate-cli.ts --typescript",
    "validate:db": "tsx scripts/validate-cli.ts --db",
    "validate:json": "tsx scripts/validate-cli.ts --json",
    "validate:verbose": "tsx scripts/validate-cli.ts --verbose",
    "test": "jest",
    "test:ci": "jest --testPathIgnorePatterns=\"api-e2e|payment-edge-cases|payment-workflows-integration|plan-inference|payment-dedupe-clustering|whatsapp-import\"",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:deployment": "npm run validate && npm run test:endpoints",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:prod": "BASE_URL=${BASE_URL:-https://fitness360.vercel.app} playwright test",
    "precommit": "npm run validate:quick && npm run lint",
    "cleanup:duplicates": "tsx scripts/cleanup-duplicate-payments.ts",
    "db:anonymize-members": "tsx scripts/anonymize-member-pii.ts",
    "db:seed-demo-gym": "tsx scripts/seed-demo-gym.ts",
    "mcp:setup": "tsx scripts/mcp-setup.ts",
    "mcp:server": "sh scripts/run-mcp-server.sh"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.81",
    "@ai-sdk/openai": "^3.0.67",
    "@auth/prisma-adapter": "^2.11.1",
    "@browserbasehq/sdk": "^2.6.0",
    "@hookform/resolvers": "^5.2.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@prisma/client": "^6.19.2",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-aspect-ratio": "^1.1.8",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-menubar": "^1.1.16",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@supabase/ssr": "^0.6.1",
    "@supabase/supabase-js": "^2.101.1",
    "@tanstack/react-table": "^8.21.3",
    "@types/node-cron": "^3.0.11",
    "@types/nprogress": "^0.2.3",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.34.3",
    "ai": "^6.0.193",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "embla-carousel": "^8.6.0",
    "html2canvas": "^1.4.1",
    "inngest": "^3.41.0",
    "jspdf": "^4.2.0",
    "lucide-react": "^0.563.0",
    "next": "16.1.6",
    "next-auth": "^5.0.0-beta.30",
    "node-cron": "^4.2.1",
    "nprogress": "^0.2.0",
    "playwright-core": "^1.58.2",
    "prisma": "^6.19.2",
    "qrcode-terminal": "^0.12.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.71.1",
    "recharts": "^3.8.0",
    "sonner": "^2.0.7",
    "swr": "^2.4.1",
    "tailwind-merge": "^3.4.0",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.4.0",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/xlsx": "^0.0.35",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "jest": "^30.3.0",
    "tailwindcss": "^4",
    "ts-jest": "^29.4.6",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
