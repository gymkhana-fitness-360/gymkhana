# GymFlo MCP (gitignored copy: .env.mcp.local)
# Setup: npm run db:seed-demo-gym && npx tsx scripts/seed-oauth-clients.ts && npm run mcp:setup

GYMFLO_API_URL=http://127.0.0.1:3000

# Written by seed-oauth-clients.ts
GYMFLO_MCP_CLIENT_ID=
GYMFLO_MCP_CLIENT_SECRET=

# Written by npm run mcp:setup (Bearer for /api/agent/v1/tools/*)
GYMFLO_AGENT_TOKEN=

# Optional; must be allowed on the AGENT client
# GYMFLO_MCP_SCOPES=read:overdue read:members read:payments read:analytics write:reminders
