# =============================================================================
# Fitness360 environment template
#
# Local:  cp .env.example .env  → fill values (see docs/SECURITY.md)
# Vercel: Project → Settings → Environment Variables (do not commit .env.production)
# Pull:   vercel env pull .env.production --environment=production
#
# Secrets: openssl rand -base64 32
# =============================================================================

# --- Database (Prisma) ---
# Use one Postgres instance. For local/single-URL hosts, set BOTH to the same string.
# See prisma/ENV.md and docs/DATABASE_MIGRATION.md (do not use Supabase :6543 pooler for new DBs).
DATABASE_URL="postgresql://user:password@localhost:5432/fitness360"
DIRECT_DATABASE_URL="postgresql://user:password@localhost:5432/fitness360"

NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET=""

# --- OAuth sign-in (optional) ---
# Google: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: {NEXTAUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
# GitHub: Settings → Developer settings → OAuth Apps
# Authorization callback URL: {NEXTAUTH_URL}/api/auth/callback/github
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# --- Required in production ---
CRON_SECRET=""
QR_SECRET=""

# --- Branding (white-label) ---
# App name shown in product chrome, PWA manifest, and receipts. Default "Fitness360".
# Set at build time (NEXT_PUBLIC_* is inlined into the client bundle).
NEXT_PUBLIC_APP_NAME="Fitness360"
# Commercial site (`cloud/` repo): www.gymkhana.fit — local dev: http://localhost:3001
NEXT_PUBLIC_MARKETING_SITE_URL="https://www.gymkhana.fit"
# NEXT_PUBLIC_MARKETING_SITE_URL="http://localhost:3001"

# --- Application ---
NODE_ENV="development"
ALLOW_DEMO_ACCOUNT_AUTO_LINK="false"

# --- Feature gates (default off in production) ---
# ENABLE_PLAYGROUND="true"
# ENABLE_DEVELOPERS_PORTAL="true"
# ENABLE_AGENT_API="true"

# --- Dev-only Inngest self-heal (rm -rf .next, npm install) — never enable on Vercel prod ---
ENABLE_DEV_SELF_HEAL="false"

# Admin reserved member IDs: map phone digits to externalId, e.g. 9639627371=MEM000
PROTECTED_ADMIN_PHONE_MAP=""
# Tenant-specific member protection (default off for OSS)
MEMBER_PROTECTION_ENABLED="false"

# --- Supabase (optional) ---
# Only NEXT_PUBLIC_* are exposed to the browser; never put service role in NEXT_PUBLIC_
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# --- Inngest (optional background jobs) ---
INNGEST_EVENT_KEY=""
INNGEST_SIGNING_KEY=""

# --- Push (optional) ---
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""

# --- WhatsApp Business API (Meta Cloud) — recommended for production ---
META_WABA_ACCESS_TOKEN=""
META_WABA_PHONE_NUMBER_ID=""
# META_WABA_FORCE="1"
# Per-gym: Setting key wabaEnabled:{gymId} = "true"

# --- AI inference (Fitness360 AI chat + recovery readiness on Renewals) ---
# Provider: groq | anthropic — uses Vercel AI SDK generateObject
FITNESS360_AI_PROVIDER="groq"
FITNESS360_INFERENCE_ENABLED="true"
# Public demo: cap LLM spend (FITNESS360_INFERENCE_MAX_MEMBERS_PER_RUN, FITNESS360_INFERENCE_CRON_LLM=false)
# FITNESS360_INFERENCE_MAX_MEMBERS_PER_RUN="5"
# FITNESS360_INFERENCE_COHORT_BRIEF="false"
# Nightly cron: false on demo/prod (default prod=off). true only if you want batch LLM at 2am.
FITNESS360_INFERENCE_CRON_LLM="false"
# MCP dashboard tokens (default 7 days). Settings → AI & MCP auto-refreshes connect bundle.
# FITNESS360_MCP_TOKEN_TTL_SECONDS="604800"
# Groq — https://console.groq.com
FITNESS360_AI_API_KEY=""
FITNESS360_AI_MODEL="qwen/qwen3-32b"
# Readiness queue only — Groq models with structured output, e.g. openai/gpt-oss-20b
FITNESS360_INFERENCE_MODEL="openai/gpt-oss-20b"
# Anthropic — set FITNESS360_AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-3-5-haiku-latest"

# --- Razorpay (marketplace: razorpay-payments) ---
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
RAZORPAY_WEBHOOK_SECRET=""

# --- WhatsApp Business API (marketplace app credentials) ---
WHATSAPP_BUSINESS_PHONE_ID=""
WHATSAPP_BUSINESS_TOKEN=""
