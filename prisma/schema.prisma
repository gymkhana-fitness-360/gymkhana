// Schema conventions:
// - Scalar / FK fields: camelCase (gymId, accountId).
// - Relation fields: PascalCase matching the related model (Member, Gym).
// - Outbound comms: MessageLog, ReminderLog, WhatsAppSendLog overlap historically; new writes use CommunicationEvent.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // App runtime: DATABASE_URL
  url       = env("DATABASE_URL")
  // Migrations / studio: DIRECT_DATABASE_URL (same as DATABASE_URL when host has no separate direct URL)
  directUrl = env("DIRECT_DATABASE_URL")
}

enum AccountPlan {
  FREE
  PRO
  ENTERPRISE
}

/// Franchise / agency membership role (per account).
enum AccountMemberRole {
  OWNER
  ADMIN
  STAFF
}

enum OAuthClientType {
  ACCOUNT
  AGENT
}

model Account {
  id                 String               @id @default(uuid()) @db.Uuid
  name               String
  plan               AccountPlan          @default(FREE)
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  User               User[]
  Gym                Gym[]
  AccountMembership  AccountMembership[]
  OAuthClient        OAuthClient[]
}

/// User ↔ Account (multi-org). Replaces implicit single `User.accountId` for authorization.
model AccountMembership {
  id        String            @id @default(cuid())
  userId    String
  accountId String            @db.Uuid
  role      AccountMemberRole @default(STAFF)
  isActive  Boolean           @default(true)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  User      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  Account   Account           @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([userId, accountId])
  @@index([accountId])
  @@index([userId])
}

/// M2M OAuth client (account integrations or per-gym agents). Secrets stored hashed.
model OAuthClient {
  id               String          @id @default(cuid())
  clientId         String          @unique
  clientSecretHash String
  type             OAuthClientType
  accountId        String          @db.Uuid
  gymId            String?         @db.Uuid
  name             String
  scopes           String[]
  isActive         Boolean         @default(true)
  revokedAt        DateTime?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  Account          Account         @relation(fields: [accountId], references: [id], onDelete: Cascade)
  Gym              Gym?            @relation(fields: [gymId], references: [id], onDelete: Cascade)
  OAuthAccessToken OAuthAccessToken[]

  @@index([accountId])
  @@index([gymId])
}

model OAuthAccessToken {
  id        String      @id @default(cuid())
  tokenHash String      @unique
  clientId  String
  accountId String      @db.Uuid
  gymId     String?     @db.Uuid
  scopes    String[]
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime    @default(now())
  OAuthClient OAuthClient @relation(fields: [clientId], references: [clientId], onDelete: Cascade)

  @@index([clientId])
  @@index([accountId])
  @@index([expiresAt])
}

model Gym {
  id                   String                 @id @default(uuid()) @db.Uuid
  accountId            String                 @db.Uuid
  name                 String
  publicBookSlug       String?                @unique
  address              String?
  phone                String?
  email                String?
  gstin                String?
  invoiceLegalName     String?
  invoiceStateCode     String?
  logoUrl              String?
  financialYearStart   DateTime?              @db.Date
  financialYearEnd     DateTime?              @db.Date
  currencyCode         String                 @default("INR")
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  Account              Account                @relation(fields: [accountId], references: [id], onDelete: Cascade)
  Member               Member[]
  Payment              Payment[]
  Membership           Membership[]
  Bill                 Bill[]
  Achievement          Achievement[]
  Attendance           Attendance[]
  Reminder             Reminder[]
  OverdueTracking      OverdueTracking[]
  TrainerClient        TrainerClient[]
  TrainerCommission    TrainerCommission[]
  Workout              Workout[]
  ExpectedPayment      ExpectedPayment[]
  MessageLog           MessageLog[]
  ChurnPrediction      ChurnPrediction[]
  ReminderLog          ReminderLog[]
  WhatsAppSendLog      WhatsAppSendLog[]
  CommunicationEvent   CommunicationEvent[]
  Opportunity          Opportunity[]
  Challenge            Challenge[]
  ChallengeParticipant ChallengeParticipant[]
  Expense              Expense[]
  Salary               Salary[]
  Plan                 Plan[]
  AttendanceUpload     AttendanceUpload[]
  FreeTrialVisit       FreeTrialVisit[]
  AuditLog             AuditLog[]
  GymClass             GymClass[]
  ClassBooking         ClassBooking[]
  MarketplaceInstall   GymMarketplaceInstall[]
  PaymentCheckoutLink  PaymentCheckoutLink[]
  OAuthClient          OAuthClient[]
  Goal                 Goal[]
  Approval             Approval[]
  Offer                Offer[]
  Product              Product[]
  DietPlanAssignment   DietPlanAssignment[]
  Lead                 Lead[]
  OrderLine            OrderLine[]
  WhatsAppTemplate     WhatsAppTemplate[]
  WhatsAppCampaign     WhatsAppCampaign[]
  SupplementGstInvoice SupplementGstInvoice[]
  GymFact                GymFact[]
  Service                Service[]
  InvoiceTransaction   InvoiceTransaction[]
  LeadFollowUp         LeadFollowUp[]
  StaffNotification    StaffNotification[]
  AdminTask            AdminTask[]
  DailyStats           DailyStats[]
  ErrorLog             ErrorLog[]
  CustomEntityDefinition CustomEntityDefinition[]
  CustomEntityRecord   CustomEntityRecord[]
  CustomAnalyticsDefinition CustomAnalyticsDefinition[]

  @@index([accountId])
}

enum CustomFieldType {
  TEXT
  NUMBER
  BOOLEAN
  DATE
  SELECT
}

enum CustomAnalyticsSource {
  MEMBERS
  PAYMENTS
  ATTENDANCE
  CUSTOM_ENTITY
}

enum CustomAnalyticsAggregation {
  COUNT
  SUM
  AVG
}

model CustomEntityDefinition {
  id          String   @id @default(cuid())
  gymId       String   @db.Uuid
  slug        String
  name        String
  description String?
  fields      Json
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  Gym         Gym      @relation(fields: [gymId], references: [id], onDelete: Cascade)
  Records     CustomEntityRecord[]

  @@unique([gymId, slug])
  @@index([gymId])
}

model CustomEntityRecord {
  id        String                 @id @default(cuid())
  gymId     String                 @db.Uuid
  entityId  String
  data      Json
  createdAt DateTime               @default(now())
  updatedAt DateTime               @updatedAt
  Gym       Gym                    @relation(fields: [gymId], references: [id], onDelete: Cascade)
  Entity    CustomEntityDefinition @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@index([gymId, entityId])
}

model CustomAnalyticsDefinition {
  id          String                     @id @default(cuid())
  gymId       String                     @db.Uuid
  slug        String
  name        String
  description String?
  source      CustomAnalyticsSource
  aggregation CustomAnalyticsAggregation @default(COUNT)
  fieldKey    String?
  entitySlug  String?
  filters     Json?
  groupBy     String?
  isActive    Boolean                    @default(true)
  createdAt   DateTime                   @default(now())
  updatedAt   DateTime                   @updatedAt
  Gym         Gym                        @relation(fields: [gymId], references: [id], onDelete: Cascade)

  @@unique([gymId, slug])
  @@index([gymId])
}

model Service {
  id          String   @id @default(cuid())
  gymId       String   @db.Uuid
  name        String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  Gym         Gym      @relation(fields: [gymId], references: [id], onDelete: Cascade)
  Plan        Plan[]

  @@index([gymId])
  @@unique([gymId, name])
}

enum GymFactType {
  METRIC
  INSIGHT
  AGGREGATE
}

model GymFact {
  id        String      @id @default(cuid())
  gymId     String      @db.Uuid
  factKey   String
  factType  GymFactType @default(METRIC)
  value     Json
  source    String
  validAt   DateTime    @default(now())
  createdAt DateTime    @default(now())
  Gym       Gym         @relation(fields: [gymId], references: [id], onDelete: Cascade)

  @@unique([gymId, factKey])
  @@index([gymId, factType])
}

model Achievement {
  id          String   @id @default(cuid())
  gymId       String   @db.Uuid
  memberId    String
  name        String
  description String
  icon        String?
  earnedAt    DateTime @default(now())
  Gym         Gym      @relation(fields: [gymId], references: [id], onDelete: Cascade)
  Member      Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([earnedAt])
  @@index([gymId])
  @@index([memberId])
}

model Attendance {
  id         String           @id @default(cuid())
  gymId      String           @db.Uuid
  memberId   String
  checkIn    DateTime         @default(now())
  checkOut   DateTime?
  location   String?
  qrCodeData String?
  method     AttendanceMethod @default(MANUAL)
  Gym        Gym              @relation(fields: [gymId], references: [id], onDelete: Cascade)
  Member     Member           @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([checkIn])
  @@index([gymId])
  @@index([memberId])
  @@index([memberId, checkIn])
  @@index([checkIn, method])
  @@index([gymId, checkIn])
}

/// Walk-in visitors: free trial (max 2 per phone, lifetime) or paid day pass (flexible amount).
model FreeTrialVisit {
  id              String           @id @default(cuid())
  gymId           String           @db.Uuid
  kind            WalkInVisitKind
  name            String
  phone           String
  visitDate       DateTime         @db.Date
  amount          Decimal?         @db.Decimal(10, 2)
  notes           String?
  ptSessionCount  Int?
  createdById String?
  createdAt   DateTime         @default(now())
  Gym         Gym              @relation(fields: [gymId], references: [id], onDelete: Cascade)
  User        User?            @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@index([gymId])
  @@index([visitDate])
  @@index([phone])
  @@index([gymId, phone, kind])
  @@index([gymId, visitDate, kind])
}

model Bill {
  id               String        @id @default(cuid())
  gymId            String        @db.Uuid
  memberId         String
  billNumber       String
  programType      ProgramType
  amount           Decimal?      @db.Decimal(10, 2)
  paymentMethod    PaymentMethod
  month            String
  validFrom        DateTime
  validTo          DateTime
  nextPaymentDate  DateTime?
  workoutPlan      String
  hideAmount       Boolean       @default(false)
  notes            String?
  generatedById    String
  billSentAt       DateTime?
  status           BillStatus    @default(ISSUED)
  dueDate          DateTime?     @db.Date
  tax              Decimal?      @db.Decimal(10, 2)
  discountAmount   Decimal?      @db.Decimal(10, 2)
  discountNote     String?
  subscriptionFee  Decimal?      @db.Decimal(10, 2)
  paidAmount       Decimal       @default(0) @db.Decimal(10, 2)
  dueAmount        Decimal       @default(0) @db.Decimal(10, 2)
  membershipId     String?
  deletedAt        DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  Gym              Gym           @relation(fields: [gymId], references: [id], onDelete: Cascade)
  User             User          @relation(fields: [generatedById], references: [id])
  Member           Member        @relation(fields: [memberId], references: [id], onDelete: Cascade)
  Membership       Membership?   @relation(fields: [membershipId], references: [id], onDelete: SetNull)
  Payment          Payment[]
  InvoiceTransaction InvoiceTransaction[]
  ExpectedPayment  ExpectedPayment[]

  @@unique([gymId, billNumber])
  @@index([billNumber])
  @@index([createdAt])
  @@index([gymId])
  @@index([memberId])
  @@index([status])
  @@index([dueDate])
  @@index([deletedAt])
}

model Challenge {
  id                   String                 @id @default(cuid())
  gymId                String                 @db.Uuid
  name                 String
  description          String
  type                 ChallengeType
  status               ChallengeStatus        @default(UPCOMING)
  startDate            DateTime
  endDate              DateTime
  targetValue          Int?
  prize                String?
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  Gym                  Gym                    @relation(fields: [gymId], references: [id], onDelete: Cascade)
  ChallengeParticipant ChallengeParticipant[]

  @@index([endDate])
  @@index([gymId])
  @@index([startDate])
  @@index([status])
}

model ChallengeParticipant {
  id           String    @id @default(cuid())
  gymId        String    @db.Uuid
  challengeId  String
  memberId     String
  currentValue Int       @default(0)
  rank         Int?
  isWinner     Boolean   @default(false)
  joinedAt     DateTime  @default(now())
  Gym          Gym       @relation(fields: [gymId], references: [id], onDelete: Cascade)
  Challenge    Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  Member       Member    @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([challengeId, memberId])
  @@index([challengeId])
  @@index([gymId])
  @@index([memberId])
}

model Expense {
  id           String          @id @default(cuid())
  gymId        String          @db.Uuid
  description  String
  category     ExpenseCategory
  type         ExpenseType     @default(ONE_TIME)
  amount       Decimal         @db.Decimal(10, 2)
  paymentDate  DateTime
  method       PaymentMethod
  vendor       String?
  reference    String?
  notes        String?
  nextDueDate  DateTime?
  status       ExpenseStatus   @default(PAID)
  dueDate      DateTime?       @db.Date
  paidAt       DateTime?
  recordedById String
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  Gym          Gym             @relation(fields: [gymId], references: [id], onDelete: Cascade)
  User         User            @relation(fields: [recordedById], references: [id])

  @@index([category])
  @@index([gymId, paymentDate])
  @@index([gymId])
  @@index([paymentDate])
  @@index([type])
  @@index([status])
  @@index([dueDate])
}

model Member {
  id                   String                 @id
  gymId                String                 @db.Uuid
  name                 String
  phone                String
  email                String?
  gender               Gender?
  dateOfBirth          DateTime?
  address              String?
  emergencyContact     String?
  photo                String?
  source               MemberAcquisitionSource?
  goal                 MemberFitnessGoal?
  healthIssue          String?
  country              String?
  state                String?
  city                 String?
  pincode              String?
  status               MemberStatus           @default(ACTIVE)
  joinDate             DateTime               @default(now())
  nextRenewalDate      DateTime?              @db.Date
  lastPaymentDate      DateTime?              @db.Date
  lastReminderSentAt   DateTime?
  createdById          String?
  deletedAt            DateTime?
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  Achievement          Achievement[]
  Attendance           Attendance[]
  Bill                 Bill[]
  ChallengeParticipant ChallengeParticipant[]
  User                 User?                  @relation(fields: [createdById], references: [id])
  Membership           Membership[]
  Payment              Payment[]
  Reminder             Reminder[]
  TrainerClient        TrainerClient[]
  TrainerCommission    TrainerCommission[]
  Workout              Workout[]
  ExpectedPayment      ExpectedPayment[]
  MessageLog           MessageLog[]
  ChurnPrediction      ChurnPrediction[]
  ReminderLogs         ReminderLog[]          @relation("ReminderLogs")
  WhatsAppSendLogs     WhatsAppSendLog[]
  CommunicationEvents  CommunicationEvent[]
  Opportunities        Opportunity[]
  OverdueTracking      OverdueTracking[]
  ClassBooking         ClassBooking[]
  PaymentCheckoutLink  PaymentCheckoutLink[]
  DietPlanAssignment   DietPlanAssignment[]
  OrderLine            OrderLine[]
  SupplementGstInvoice SupplementGstInvoice[]
  Gym                  Gym                    @relation(fields: [gymId], references: [id], onDelete: Restrict)

  @@unique([gymId, phone])
  @@index([id])
  @@index([gymId])
  @@index([phone])
  @@index([status, createdAt])
  @@index([status])
  @@index([status, joinDate])
  @@index([nextRenewalDate])
  @@index([status, nextRenewalDate])
  @@index([email])
  @@index([deletedAt])
}

model Membership {
  id                    String                     @id @default(cuid())
  gymId                 String                     @db.Uuid
  memberId              String
  planId                String
  startDate             DateTime                   @db.Date
  endDate               DateTime                   @db.Date
  amount                Decimal                    @db.Decimal(10, 2)
  previousMembershipId  String?
  sourcePaymentId       String?
  lifecycleStatus       MembershipLifecycleStatus  @default(ONGOING)
  createdAt             DateTime                   @default(now())
  Gym                   Gym                        @relation(fields: [gymId], references: [id], onDelete: Cascade)
  Member                Member                     @relation(fields: [memberId], references: [id], onDelete: Cascade)
  Plan                  Plan                       @relation(fields: [planId], references: [id])
  PreviousMembership    Membership?                @relation("MembershipRenewal", fields: [previousMembershipId], references: [id], onDelete: SetNull)
  RenewedMemberships    Membership[]               @relation("MembershipRenewal")
  Bill                  Bill[]

  @@unique([memberId, startDate, endDate])
  @@index([endDate])
  @@index([gymId])
  @@index([memberId, endDate])
  @@index([memberId])
  @@index([startDate, endDate])
  @@index([gymId, endDate])
  @@index([previousMembershipId])
  @@index([lifecycleStatus])
}

model Payment {
  id                    String           @id @default(cuid())
  gymId                 String           @db.Uuid
  memberId              String
  amount                Decimal          @db.Decimal(10, 2)
  method                PaymentMethod
  status                PaymentStatus    @default(COMPLETED)
  reference             String?
  notes                 String?
  receivedById          String
  receivedAt            DateTime         @db.Date
  paymentDate           DateTime?        @db.Date
  planId                String?
  duration              String?
  source                PaymentSource?
  createdAt             DateTime         @default(now())
  friendsFamilyDiscount Boolean          @default(false)
  isPersonalTrainer     Boolean          @default(false)
  monthlyRate           Decimal?         @db.Decimal(10, 2)
  packageDuration       String?
  specialOccasion       String?
  studentGymfloPlan     Boolean          @default(false)
  month                 Int?
  year                  Int?
  billSentAt            DateTime?
  billId                String?
  Gym                   Gym              @relation(fields: [gymId], references: [id], onDelete: Cascade)
  Member                Member           @relation(fields: [memberId], references: [id], onDelete: Cascade)
  User                  User             @relation(fields: [receivedById], references: [id])
  Plan                  Plan?            @relation(fields: [planId], references: [id])
  ExpectedPayment       ExpectedPayment?
  Bill                  Bill?            @relation(fields: [billId], references: [id], onDelete: SetNull)
  InvoiceTransaction    InvoiceTransaction[]

  @@index([gymId])
  @@index([memberId])
  @@index([memberId, receivedAt])
  @@index([memberId, paymentDate])
  @@index([method, receivedAt])
  @@index([gymId, receivedAt])
  @@index([gymId, status, receivedAt])
  @@index([receivedAt])
  @@index([paymentDate])
  @@index([status, receivedAt])
  @@index([year, month])
  @@index([memberId, status])
  @@index([billId])
}

model InvoiceTransaction {
  id            String                 @id @default(cuid())
  gymId         String                 @db.Uuid
  billId        String
  paymentId     String?
  type          InvoiceTransactionType
  amount        Decimal                @db.Decimal(10, 2)
  occurredAt    DateTime               @default(now())
  paymentMethod PaymentMethod?
  note          String?
  referenceId   String?
  createdById   String?
  createdAt     DateTime               @default(now())
  Gym           Gym                    @relation(fields: [gymId], references: [id], onDelete: Cascade)
  Bill          Bill                   @relation(fields: [billId], references: [id], onDelete: Cascade)
  Payment       Payment?               @relation(fields: [paymentId], references: [id], onDelete: SetNull)
  User          User?                  @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@index([gymId])
  @@index([billId])
  @@index([paymentId])
  @@index([occurredAt])
}

model Plan {
  id           String       @id
  gymId        String       @db.Uuid
  serviceId    String?
  name         String
  durationDays Int
  price        Decimal      @db.Decimal(10, 2)
  description  String?
  planType     PlanType     @default(GYM)
  isActive     Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  Gym          Gym          @relation(fields: [gymId], references: [id], onDelete: Cascade)
  Service      Service?     @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  Membership   Membership[]
  Payment      Payment[]

  @@index([gymId])
  @@index([planType, durationDays])
  @@index([serviceId])
}

model Reminder {
  id           String         @id @default(cuid())
  gymId        String         @db.Uuid
  memberId     String
  type         ReminderType
  message      String
  scheduledFor DateTime
  sentAt       DateTime?
  status       ReminderStatus @default(SCHEDULED)
  errorMessage String?
  createdAt    DateTime       @default(now())
  Gym          Gym            @relation(fields: [gymId], references: [id], onDelete: Cascade)
  Member       Member         @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([gymId])
  @@index([scheduledFor])
  @@index([status])
}

model Salary {
  id                           String        @id @default(cuid())
  gymId                        String        @db.Uuid
  employeeId                   String
  amount                       Decimal       @db.Decimal(10, 2)
  paymentDate                  DateTime
  month                        Int
  year                         Int
  method                       PaymentMethod
  reference                    String?
  notes                        String?
  paidById                     String
  createdAt                    DateTime      @default(now())
  Gym                          Gym           @relation(fields: [gymId], references: [id], onDelete: Cascade)
  User_Salary_employeeIdToUser User          @relation("Salary_employeeIdToUser", fields: [employeeId], references: [id], onDelete: Cascade)
  User_Salary_paidByIdToUser   User          @relation("Salary_paidByIdToUser", fields: [paidById], references: [id])

  @@index([employeeId])
  @@index([gymId, paymentDate])
  @@index([gymId])
  @@index([paymentDate])
  @@index([year, month])
}

model Setting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  description String?
  updatedAt   DateTime @updatedAt
}

model OverdueTracking {
  id              String   @id @default(cuid())
  gymId           String   @db.Uuid
  memberId        String
  month           String
  detectedAt      DateTime @default(now())
  lastSeenAt      DateTime?
  markedInactiveAt DateTime?
  resolvedAt      DateTime?
  notes           String?
  Gym             Gym      @relation(fields: [gymId], references: [id], onDelete: Cascade)
  Member          Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([memberId, month])
  @@index([gymId])
  @@index([memberId])
  @@index([detectedAt])
  @@index([markedInactiveAt])
  @@index([gymId, resolvedAt])
}

enum JobExecutionStatus {
  RUNNING
  COMPLETED
  FAILED
}

model JobExecution {
  id          String             @id @default(cuid())
  jobName     String
  status      JobExecutionStatus
  startedAt   DateTime           @default(now())
  completedAt DateTime?
  metadata    Json?
  error       String?            @db.Text

  @@index([jobName])
  @@index([jobName, status])
}

model TrainerClient {
  id        String    @id @default(cuid())
  gymId     String    @db.Uuid
  trainerId String
  memberId  String
  startDate DateTime  @default(now())
  endDate   DateTime?
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  Gym       Gym       @relation(fields: [gymId], references: [id], onDelete: Cascade)
  Member    Member    @relation(fields: [memberId], references: [id], onDelete: Cascade)
  User      User      @relation(fields: [trainerId], references: [id], onDelete: Cascade)

  @@unique([trainerId, memberId])
  @@index([gymId])
  @@index([memberId])
  @@index([trainerId])
  @@index([trainerId, isActive])
}

model TrainerCommission {
  id             String    @id @default(cuid())
  gymId          String    @db.Uuid
  trainerId      String
  memberId       String
  amount         Decimal   @db.Decimal(10, 2)
  commissionRate Decimal   @db.Decimal(5, 2)
  baseAmount     Decimal   @db.Decimal(10, 2)
  month          Int
  year           Int
  isPaid         Boolean   @default(false)
  paidDate       DateTime?
  notes          String?
  createdAt      DateTime  @default(now())
  Gym            Gym       @relation(fields: [gymId], references: [id], onDelete: Cascade)
  Member         Member    @relation(fields: [memberId], references: [id], onDelete: Cascade)
  User           User      @relation(fields: [trainerId], references: [id], onDelete: Cascade)

  @@index([gymId])
  @@index([isPaid])
  @@index([gymId, year, month])
  @@index([memberId])
