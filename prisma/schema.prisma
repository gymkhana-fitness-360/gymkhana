// Track expected vs actual payments
model ExpectedPayment {
  id             String        @id @default(cuid())
  gymId          String        @db.Uuid
  memberId       String
  membershipId   String?
  billId         String?
  dueDate        DateTime
  amount         Decimal       @db.Decimal(10, 2)
  status         PaymentStatus @default(PENDING)
  paymentId      String?       @unique
