  message        String?                @db.Text
  segment        Json?
  analytics      Json?
  recipientCount Int                    @default(0)
  status         WhatsAppCampaignStatus @default(DRAFT)
  payload        Json?
  sentAt         DateTime?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  Gym            Gym                    @relation(fields: [gymId], references: [id], onDelete: Cascade)

  @@index([gymId, status])
}

model MemberOtpChallenge {
  id        String   @id @default(cuid())
  gymId     String   @db.Uuid
  phone     String
  codeHash  String
  memberId  String?
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([gymId, phone])
}

enum LeadSource {
  WALK_IN
  WEBSITE
  WHATSAPP
  REFERRAL
  INSTAGRAM
  PHONE_CALL
  OTHER
}

enum LeadStatus {
  NEW
  CONTACTED
  TRIAL_SCHEDULED
  TRIAL_DONE
  CONVERTED
  LOST
}

model Lead {
  id                 String      @id @default(cuid())
  gymId              String      @db.Uuid
  name               String
  phone              String
  email              String?
  source             LeadSource  @default(WEBSITE)
  status             LeadStatus  @default(NEW)
  notes              String?
  followUpAt         DateTime?
  assignedToId       String?
  freeTrialVisitId   String?
  convertedMemberId  String?
  lostReason         String?
  deletedAt          DateTime?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  Gym                Gym         @relation(fields: [gymId], references: [id], onDelete: Cascade)
  LeadFollowUp       LeadFollowUp[]

  @@index([gymId, status])
  @@index([gymId, phone])
  @@index([gymId, followUpAt])
  @@index([gymId, status, createdAt])
  @@index([createdAt])
  @@index([deletedAt])
}

model LeadFollowUp {
  id            String          @id @default(cuid())
  gymId         String          @db.Uuid
  leadId        String
  userId        String?
  method        FollowUpMethod  @default(CALL)
  scheduleDate  DateTime        @db.Date
  outcome       String?
  status        FollowUpStatus  @default(PENDING)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  Gym           Gym             @relation(fields: [gymId], references: [id], onDelete: Cascade)
  Lead          Lead            @relation(fields: [leadId], references: [id], onDelete: Cascade)
  User          User?           @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([gymId])
  @@index([leadId])
  @@index([scheduleDate])
  @@index([status])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model StaffNotification {
  id        String    @id @default(cuid())
  gymId     String    @db.Uuid
  userId    String
  title     String
  body      String
  readAt    DateTime?
  createdAt DateTime  @default(now())
  Gym       Gym       @relation(fields: [gymId], references: [id], onDelete: Cascade)
  User      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([gymId, userId])
  @@index([userId, readAt])
  @@index([createdAt])
}

enum AdminTaskPriority {
  HIGH
  MEDIUM
  LOW
}

enum AdminTaskStatus {
  PENDING
  RESOLVED
  DISMISSED
}

model AdminTask {
  id          String            @id @default(cuid())
  gymId       String            @db.Uuid
  type        String
  priority    AdminTaskPriority @default(MEDIUM)
  status      AdminTaskStatus   @default(PENDING)
  title       String
  description String            @db.Text
  metadata    Json?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  resolvedAt  DateTime?
  resolvedBy  String?
  Gym         Gym               @relation(fields: [gymId], references: [id], onDelete: Cascade)

  @@index([gymId, status])
  @@index([gymId, type, status])
  @@index([gymId, priority])
  @@index([createdAt])
}

model DailyStats {
  id                    String   @id @default(cuid())
  gymId                 String   @db.Uuid
  statDate              DateTime @db.Date
  totalMembers          Int      @default(0)
  activeMembers         Int      @default(0)
  todayCheckIns         Int      @default(0)
  currentlyInGym        Int      @default(0)
  qrCheckInsToday       Int      @default(0)
  todayCollection       Decimal  @default(0) @db.Decimal(14, 2)
  todayPaymentCount     Int      @default(0)
  expiringThisWeek      Int      @default(0)
  overdueCount          Int      @default(0)
  renewalsBadge         Int      @default(0)
  monthPaymentCount     Int      @default(0)
  monthPaymentTotal     Decimal  @default(0) @db.Decimal(14, 2)
  attendanceEligible    Int      @default(0)
  attendanceActiveToday Int      @default(0)
  attendanceCheckedIn   Int      @default(0)
  attendancePending     Int      @default(0)
  updatedAt             DateTime @updatedAt
  Gym                   Gym      @relation(fields: [gymId], references: [id], onDelete: Cascade)

  @@unique([gymId, statDate])
  @@index([gymId, statDate])
  @@index([updatedAt])
}

enum ErrorLogSource {
  API
  CLIENT
  CRON
  INNGEST
  PRISMA
}

model ErrorLog {
  id         String         @id @default(cuid())
  gymId      String?        @db.Uuid
  source     ErrorLogSource
  code       String
  message    String         @db.Text
  stack      String?        @db.Text
  route      String?
  userId     String?
  prismaCode String?
  metadata   Json?
  createdAt  DateTime       @default(now())
  Gym        Gym?           @relation(fields: [gymId], references: [id], onDelete: SetNull)
  User       User?          @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([gymId, createdAt])
  @@index([source, createdAt])
  @@index([code])
  @@index([createdAt])
}

/// Transactional outbox for domain events (see src/lib/platform/outbox.ts).
model OutboxEvent {
  id          String    @id @default(cuid())
  gymId       String?   @db.Uuid
  type        String
  payload     Json
  createdAt   DateTime  @default(now())
  publishedAt DateTime?

  @@index([publishedAt, createdAt])
  @@index([gymId])
  @@index([type])
}
